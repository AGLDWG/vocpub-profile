PREFIX : <https://linked.data.gov.au/def/vocpub/validator/>
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX ont: <https://linked.data.gov.au/def/vocpub/validator>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX reg: <http://purl.org/linked-data/registry#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX time: <http://www.w3.org/2006/time#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:Requirement-2.1.02-03
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :ConceptSchemeType ;
    sh:targetNode skos:ConceptScheme ;
    schema:description "Requirement 2.1.02-03" ;
    schema:name "Requirement 2.1.02-03" ;
.

:Requirement-2.1.04
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.04 Each vocabulary MUST have exactly one title and at least one definition indicated using the skos:prefLabel and the skos:definition predicates respectively that must give textual literal values. Only one definition per language is allowed" ;
    sh:property
        :definition ,
        :prefLabel ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.04" ;
    schema:name "Requirement 2.1.04" ;
.

:Requirement-2.1.05
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.05 Each vocabulary MUST have exactly one created date and exactly one modified date indicated using the schema:dateCreated and schema:dateModified or dcterms:created and dcterms:modified predicates respectively that must be either an xsd:date, xsd:dateTime or xsd:dateTimeStamp literal value" ;
    sh:property
        :created ,
        :modified ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.05" ;
    schema:name "Requirement 2.1.05" ;
.

:Requirement-2.1.06
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.06 Each vocabulary MUST have at least one creator, indicated using schema:creator or dcterms:creator predicate and exactly one publisher, indicated using schema:publisher or dcterms:publisher, all of which MUST be IRIs indicating instances of schema:Person, or schema:Organization" ;
    sh:property
        :creator ,
        :publisher ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.06" ;
    schema:name "Requirement 2.1.06" ;
.

:Requirement-2.1.07
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.07 The origins of a Concept Scheme MUST be indicated by at least one of the following predicates: skos:historyNote, schema:citation, prov:wasDerivedFrom. dcterms:source MAY be used instead of schema:citation and dcterms:provenance MAY be used instead of skos:historyNote but the schema.org and SKOS predicates are preferred" ;
    sh:or (
        :provenance-wasDerivedFrom
        :provenance-citation
        :provenance-source
        :provenance-historyNote
        :provenance-dcterms-provenance
    ) ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.07" ;
    schema:name "Requirement 2.1.07" ;
.

:Requirement-2.1.08
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :single-term-hierarchy ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.1.08" ;
    schema:name "Requirement 2.1.08" ;
.

:Requirement-2.1.09
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :at-least-one-concept ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.09" ;
    schema:name "Requirement 2.1.09" ;
.

:Requirement-2.1.10
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :status ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.10" ;
    schema:name "Requirement 2.1.10" ;
.

:Requirement-2.1.11
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.11 The derivation status of the vocabulary SHOULD be given should be given with the predicate prov:qualifiedDerivation indicating a Blank Node that contains the predicated prov:entity, to indicate the vocabulary derived from and prov:hadRole to indicate the mode of derivation which SHOULD be taken from the Vocabulary Derivation Modes vocabulary (https://linked.data.gov.au/def/vocdermods)" ;
    sh:property :qualified-derivation ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.11" ;
    schema:name "Requirement 2.1.11" ;
.

:Requirement-2.1.11b
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :qualified-derivation-entity ;
    sh:targetObjectsOf prov:qualifiedDerivation ;
    schema:description
        "" ,
        "Requirement 2.1.11b" ;
    schema:name "Requirement 2.1.11b" ;
.

:Requirement-2.1.11c
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :qualified-derivation-role ;
    sh:targetObjectsOf prov:qualifiedDerivation ;
    schema:description "Requirement 2.1.11c" ;
    schema:name "Requirement 2.1.11c" ;
.

:Requirement-2.1.12
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :theming ;
    sh:severity sh:Warning ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.12" ;
    schema:name "Requirement 2.1.12" ;
.

:Requirement-2.1.13
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :license ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.13" ;
    schema:name "Requirement 2.1.13" ;
.

:Requirement-2.1.14
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :copyright-holder ;
    sh:severity sh:Warning ;
    sh:targetClass skos:ConceptScheme ;
    schema:description "Requirement 2.1.14" ;
    schema:name "Requirement 2.1.14" ;
.

:Requirement-2.2.01
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.04 Each Collection and Concept MUST have exactly one title and at least one definition indicated using the skos:prefLabel and the skos:definition predicates respectively that must give textual literal values. Only one definition per language is allowed" ;
    sh:property
        :definition ,
        :prefLabel ;
    sh:targetClass
        skos:Collection ,
        skos:Concept ;
    schema:description "Requirement 2.2.01" ;
    schema:name "Requirement 2.2.01" ;
.

:Requirement-2.2.02
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.2.02 The origins of a Collection, if different from its containing Concept Scheme, SHOULD be indicated by at least one of the following predicates: skos:historyNote, schema:citation, prov:wasDerivedFrom. dcterms:source MAY be used instead of schema:citation and dcterms:provenance MAY be used instead of skos:historyNote but the schema.org and SKOS predicates are preferred" ;
    sh:or (
        :provenance-wasDerivedFrom
        :provenance-citation
        :provenance-source
        :provenance-historyNote
        :provenance-dcterms-provenance
    ) ;
    sh:severity sh:Warning ;
    sh:targetClass skos:Collection ;
    schema:description "Requirement 2.2.02" ;
    schema:name "Requirement 2.2.02" ;
.

:Requirement-2.2.03
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :in-scheme ;
    sh:targetClass skos:Collection ;
    schema:description "Requirement 2.2.03" ;
    schema:name "Requirement 2.2.03" ;
.

:Requirement-2.2.03b
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :in-scheme ;
    sh:severity sh:Warning ;
    sh:targetClass skos:Collection ;
    schema:description "Requirement 2.2.03b" ;
    schema:name "Requirement 2.2.03b" ;
.

:Requirement-2.2.04
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :member ;
    sh:targetClass skos:Collection ;
    schema:description "Requirement 2.2.04" ;
    schema:name "Requirement 2.2.04" ;
.

:Requirement-2.3.02
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.3.2 Each Concept in a vocabulary MAY indicate the vocabulary that defines it by use of the rdfs:isDefinedBy predicate indicating a Concept Scheme instance. If no such predicate is given, the Concept Scheme in the file that a Concept is provided in is understood to be the defining Concept Scheme" ;
    sh:property :is-defined-by ;
    sh:severity sh:Warning ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.02" ;
    schema:name "Requirement 2.3.02" ;
.

:Requirement-2.3.03
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :in-scheme ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.03" ;
    schema:name "Requirement 2.3.03" ;
.

:Requirement-2.3.04
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.2.02 The origins of a Concept, if different from its containing Concept Scheme, SHOULD be indicated by at least one of the following predicates: skos:historyNote, schema:citation, prov:wasDerivedFrom. dcterms:source MAY be used instead of schema:citation and dcterms:provenance MAY be used instead of skos:historyNote but the schema.org and SKOS predicates are preferred" ;
    sh:or (
        :provenance-wasDerivedFrom
        :provenance-citation
        :provenance-source
        :provenance-historyNote
        :provenance-dcterms-provenance
    ) ;
    sh:severity sh:Warning ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.04" ;
    schema:name "Requirement 2.3.04" ;
.

:Requirement-2.3.05
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :status ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.05" ;
    schema:name "Requirement 2.3.05" ;
.

:Requirement-2.3.10
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :notation ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.10" ;
    schema:name "Requirement 2.3.10" ;
.

:Requirement-2.3.11
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:targetClass skos:Concept ;
    sh:xone (
        :concept-historyNote-string
        :concept-historyNote-lang
        :concept-historyNote-none
    ) ;
    sh:message "Requirement 2.3.11 If a Concept indicates a skos:historyNote, its range value MUST be a literal. A plain string value (xsd:string) may be used or, if values in multiple languages are desired, then multiple language string literals (rdf:langString) may be used, but ony one per language and plain strings and language strings should not be mixed" ;
    schema:name "Requirement 2.3.11" ;
.

:Requirement-2.3.12
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :concept-wasDerivedFrom ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.12" ;
    schema:name "Requirement 2.3.12" ;
.

:Requirement-2.3.13
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :concept-revisionOf ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.13" ;
    schema:name "Requirement 2.3.13" ;
.

:Requirement-2.3.14
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :concept-replaces ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.14" ;
    schema:name "Requirement 2.3.14" ;
.

:Requirement-2.3.15
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :concept-isReplacedBy ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.15" ;
    schema:name "Requirement 2.3.15" ;
.

:Requirement-2.3.16
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :concept-version ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.16" ;
    schema:name "Requirement 2.3.16" ;
.

:Requirement-2.3.17
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :concept-date-created ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.17" ;
    schema:name "Requirement 2.3.17" ;
.

:Requirement-2.3.18
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :concept-date-modified ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.18" ;
    schema:name "Requirement 2.3.18" ;
.

:Requirement-2.3.19
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :concept-temporalCoverage ;
    sh:targetClass skos:Concept ;
    schema:description "Requirement 2.3.19" ;
    schema:name "Requirement 2.3.19" ;
.

:Requirement-2.3.19-start
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:and (
        :temporal-entity-start-date-type
        :temporal-entity-end-date-type
        
        [
            sh:or (
                :temporal-entity-start-date-one
                :temporal-entity-end-date-one
            ) ;
        ]
    ) ;
    sh:targetClass time:TemporalEntity ;
    sh:message "Requirement 2.3.19 If a Concept indicates a temporal coverage, its range value MUST be a temporal entity (time:TemporalEntity) with either or both schema:startDate and schema:endDate values which must be dates (xsd:date)" ;
    schema:name "Requirement 2.3.19-temporal-entity" ;
.

:Requirement-2.4.02
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:targetClass
        schema:Organization ,
        schema:Person ;
    sh:xone (
        :agent-name
        :agent-name2
    ) ;
    schema:description "Requirement 2.4.02" ;
    schema:name "Requirement 2.4.02" ;
.

:Requirement-2.4.03a
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :agent-url ;
    sh:targetClass schema:Organization ;
    schema:description "Requirement 2.4.03a" ;
    schema:name "Requirement 2.4.03a" ;
.

:Requirement-2.4.03b
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :agent-email ;
    sh:targetClass schema:Person ;
    schema:description "Requirement 2.4.03b" ;
    schema:name "Requirement 2.4.03b" ;
.

:ConceptSchemeType
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.02 Each vocabulary MUST be presented as a single Concept Scheme object & Requirement 2.1.3 Each vocabulary MUST be presented in a single RDF file which does not contain information other than that which is directly part of the vocabulary" ;
    sh:path
        [
            sh:inversePath rdf:type ;
        ] ;
    sh:qualifiedMaxCount 1 ;
    sh:qualifiedMinCount 1 ;
    sh:qualifiedValueShape
        [
            sh:hasValue skos:ConceptScheme ;
            sh:path rdf:type ;
        ] ;
    schema:name "single Concept Scheme" ;
.

:agent-email
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:anyURI ;
    sh:message "Requirement 2.4.3 Each Person MUST indicate an email address with the schema:email predicate, pointing to an xsd:anyURI value" ;
    sh:minCount 1 ;
    sh:path schema:email ;
    schema:name "agent email" ;
.

:agent-name
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype rdf:langString ;
    sh:message "Requirement 2.4.2 Each Agent MUST have at least one name indicated with the schema:name predicate, pointing to a literal text value. If multiple names in multiple languages are desired, then multiple schema:name values are permitted with langString literals, but ony one per language" ;
    sh:minCount 1 ;
    sh:path schema:name ;
    sh:uniqueLang true ;
    schema:name "agent name" ;
.

:agent-name2
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.4.2 Each Agent MUST have at least one name indicated with the schema:name predicate, pointing to a literal text value. If multiple names in multiple languages are desired, then multiple schema:name values are permitted with langString literals, but ony one per language" ;
    sh:minCount 1 ;
    sh:path schema:name ;
    schema:name "agent name" ;
.

:agent-url
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:anyURI ;
    sh:message "Requirement 2.4.3 Each Organization MUST indicate a website with the schema:url predicate, pointing to an xsd:anyURI value" ;
    sh:minCount 1 ;
    sh:path schema:url ;
    schema:name "agent url" ;
.

:at-least-one-concept
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:class skos:Concept ;
    sh:message "Requirement 2.1.09 Each vocabulary's Concept Scheme MUST link to at least one Concept within the vocabulary with the skos:hasTopConcept predicate" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path skos:hasTopConcept ;
    schema:name "at least one concept" ;
.

:concept-date-created
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:date ;
    sh:message "Requirement 2.3.17 If a Concept indicates a date created, its range value MUST be a date (xsd:date)" ;
    sh:path schema:dateCreated ;
    schema:name "concept date created" ;
.

:concept-date-modified
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:date ;
    sh:message "Requirement 2.3.18 If a Concept indicates a date modified, its range value MUST be a date (xsd:date)" ;
    sh:path schema:dateModified ;
    schema:name "concept date modified" ;
.

:concept-historyNote-lang
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype rdf:langString ;
    sh:message "Requirement 2.3.11 If a Concept indicates a skos:historyNote, its range value MUST be a literal. A plain string value (xsd:string) may be used or, if values in multiple languages are desired, then multiple language string literals (rdf:langString) may be used, but ony one per language and plain strings and language strings should not be mixed" ;
    sh:minCount 1 ;
    sh:path skos:historyNote ;
    sh:uniqueLang true ;
    schema:name "concept history note lang" ;
.

:concept-historyNote-string
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:message "Requirement 2.3.11 If a Concept indicates a skos:historyNote, its range value MUST be a literal. A plain string value (xsd:string) may be used or, if values in multiple languages are desired, then multiple language string literals (rdf:langString) may be used, but ony one per language and plain strings and language strings should not be mixed" ;
    sh:path skos:historyNote ;
    schema:name "concept history note string" ;
.

:concept-historyNote-none
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 0 ;
    sh:message "Requirement 2.3.11 If a Concept indicates a skos:historyNote, its range value MUST be a literal. A plain string value (xsd:string) may be used or, if values in multiple languages are desired, then multiple language string literals (rdf:langString) may be used, but ony one per language and plain strings and language strings should not be mixed" ;
    sh:path skos:historyNote ;
    schema:name "concept history note none" ;
.

:concept-isReplacedBy
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.3.15 If a Concept indicates is replaced by, its range value MUST be an IRI" ;
    sh:nodeKind sh:IRI ;
    sh:path dcterms:isReplacedBy ;
    schema:name "is replaced by" ;
.

:concept-replaces
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.3.14 If a Concept indicates replaces, its range value MUST be an IRI" ;
    sh:nodeKind sh:IRI ;
    sh:path dcterms:replaces ;
    schema:name "replaces" ;
.

:concept-revisionOf
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.3.13 If a Concept indicates revision of, its range value MUST be an IRI" ;
    sh:nodeKind sh:IRI ;
    sh:path prov:revisionOf ;
    schema:name "concept revision of" ;
.

:concept-temporalCoverage
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:class time:TemporalEntity ;
    sh:message "Requirement 2.3.19 If a Concept indicates a temporal coverage, its range value MUST be a temporal entity (time:TemporalEntity) with either or both schema:startDate and schema:endDate values which must be dates (xsd:date)" ;
    sh:path schema:temporalCoverage ;
    schema:name "concept date modified" ;
.

:concept-version
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:string ;
    sh:message "Requirement 2.3.16 If a Concept indicates version, its range value MUST be a plain string (xsd:string)" ;
    sh:path schema:version ;
    schema:name "concept version" ;
.

:concept-wasDerivedFrom
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.3.12 If a Concept indicates was derived from, its range value MUST be an IRI" ;
    sh:nodeKind sh:IRI ;
    sh:path prov:wasDerivedFrom ;
    schema:name "concept was derived from" ;
.

:copyright-holder
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.14 The copyright holder for the vocabulary SHOULD be given using the schema:copyrightHolder predicate preferentially indicating the IRI of an Agent or a Blank Node instance of an Agent containing details as per Agent requirements. A prov:qualifiedAttribution predicate indicating an Agent with the prov:hadRole predicate indicating the value isorole:rightsHolder may be used instead of schema:copyrightHolder" ;
    sh:nodeKind sh:IRI ;
    sh:path schema:copyrightHolder ;
    schema:name "copyright holder" ;
.

:created
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.15 - created date - violated" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:dateTime ;
        ]
        
        [
            sh:datatype xsd:date ;
        ]
        
        [
            sh:datatype xsd:dateTimeStamp ;
        ]
    ) ;
    sh:path
        [
            sh:alternativePath (
                schema:dateCreated
                dcterms:created
            ) ;
        ] ;
    schema:name "created" ;
.

:creator
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.06 Each vocabulary MUST have at least one creator, indicated using schema:creator or dcterms:creator predicate and exactly one publisher, indicated using schema:publisher or dcterms:publisher, all of which MUST be IRIs indicating instances of schema:Person, or schema:Organization. This error message is for creator" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:class schema:Organization ;
        ]
        
        [
            sh:class schema:Person ;
        ]
    ) ;
    sh:path
        [
            sh:alternativePath (
                schema:creator
                dcterms:creator
            ) ;
        ] ;
    schema:name "creator" ;
.

:is-defined-by
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.2.03 Collections and Concepts SHOULD indicate the vocabulary that defines it with the rdfs:isDefinedBy predicate" ;
    sh:minCount 1 ;
    sh:path rdfs:isDefinedBy ;
    schema:name "is defined by" ;
.

:license
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.13 Any licence pertaining to the reuse of a vocabulary's content SHOULD be given using the schema:license predicate preferentially indicating the IRI of a license if in RDF form or a literal URL (datatype xsd:anyURI) if online but not in RDF form. If the licence is expressed in text, a literal text field may be indicated" ;
    sh:or (
        
        [
            sh:nodeKind sh:IRI ;
        ]
        
        [
            sh:datatype xsd:anyURI ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path schema:license ;
    sh:severity sh:Warning ;
    schema:name "license" ;
.

:member
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.2.04 A Collection MUST indicate at least one Concept instance that is within the collection with use of the skos:member predicate. The Concept need not be defined by the Concept Scheme that defines the Collection" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path skos:member ;
    schema:name "member" ;
.

:modified
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.15 - modified date - violated" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:dateTime ;
        ]
        
        [
            sh:datatype xsd:date ;
        ]
        
        [
            sh:datatype xsd:dateTimeStamp ;
        ]
    ) ;
    sh:path
        [
            sh:alternativePath (
                schema:dateModified
                dcterms:modified
            ) ;
        ] ;
    schema:name "modified" ;
.

:notation
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.3.10 If a Concept indicates a skos:notation, its range value MUST be a literal. Note that it SHOULD be of a custom datatype" ;
    sh:nodeKind sh:Literal ;
    sh:path skos:notation ;
    sh:severity sh:Violation ;
    schema:name "notation" ;
.

:publisher
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.06 Each vocabulary MUST have at least one creator, indicated using schema:creator or dcterms:creator predicate and exactly one publisher, indicated using schema:publisher or dcterms:publisher, all of which MUST be IRIs indicating instances of schema:Person, or schema:Organization. This error message is for publisher" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:class schema:Organization ;
        ]
        
        [
            sh:class schema:Person ;
        ]
    ) ;
    sh:path
        [
            sh:alternativePath (
                schema:publisher
                dcterms:publisher
            ) ;
        ] ;
    schema:name "publisher" ;
.

:qualified-derivation
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.11 The derivation status of the vocabulary SHOULD be given should be given with the predicate prov:qualifiedDerivation indicating a Blank Node that contains the predicated prov:entity, to indicate the vocabulary derived from and prov:hadRole to indicate the mode of derivation which SHOULD be taken from the Vocabulary Derivation Modes vocabulary (https://linked.data.gov.au/def/vocdermods)" ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path prov:qualifiedDerivation ;
    schema:name "qualified derivation" ;
.

:qualified-derivation-entity
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.1.11 If a vocabulary has a qualified derivation given, it MUST then give a prove:entity predicate within the derivation, indicating the IRI of the vocabulary it is derived from" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path prov:entity ;
    schema:name "qualified derivation agent" ;
.

:qualified-derivation-role
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.1.11 If a vocabulary has a qualified derivation given, it MUST then give a prove:hadRole predicate within the derivation, indicating the IRI of the role" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path prov:hadRole ;
    schema:name "qualified derivation role" ;
.

:single-term-hierarchy
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:class skos:ConceptScheme ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.1.08 All Concept instances within a Concept Scheme MUST be contained in a single term hierarchy using skos:hasTopConcept / skos:topConceptOf predicates indicating the broadest Concepts in the vocabulary and then skos:broader and/or skos:narrower predicates for all non-broadest Concepts in a hierarchy that contains no cycles" ;
    sh:minCount 1 ;
    sh:path skos:inScheme ;
    schema:name "single term hierarchy" ;
.

:temporal-entity-end-date-one
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.3.19 A Temporal Entity (time:TemporalEntity) must indicate either or both a start date (schema:startDate) and an end date (schema:endDate) value" ;
    sh:minCount 1 ;
    sh:path schema:endDate ;
    schema:name "temporal entity end date one" ;
.

:temporal-entity-end-date-type
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:date ;
    sh:message "Requirement 2.3.19 If a Temporal Entity (time:TemporalEntity) indicates an end date (schema:startDate) value, it must be a literal date (xsd:date)" ;
    sh:path schema:endDate ;
    schema:name "temporal entity end date type" ;
.

:temporal-entity-start-date-one
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.3.19 A Temporal Entity (time:TemporalEntity) must indicate either or both a start date (schema:startDate) and an end date (schema:endDate) value" ;
    sh:minCount 1 ;
    sh:path schema:startDate ;
    schema:name "temporal entity end date one" ;
.

:temporal-entity-start-date-type
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:date ;
    sh:message "Requirement 2.3.19 If a Temporal Entity (time:TemporalEntity) indicates a start date (schema:startDate) value, it must be a literal date (xsd:date)" ;
    sh:path schema:startDate ;
    schema:name "temporal entity start date type" ;
.

:theming
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.12 High-level theming of a vocabulary SHOULD be given by using the schema:keywords predicate indicating Concepts from another vocabulary. Alternatively, dcat:theme MAY be used. Text literal values for either predicate SHOULD NOT be used" ;
    sh:nodeKind sh:IRI ;
    sh:path
        [
            sh:alternativePath (
                schema:keywords
                dcat:theme
            ) ;
        ] ;
    schema:name "theming" ;
.

<https://linked.data.gov.au/org/agldwg>
    a schema:Organization ;
    schema:name "Australian Government Linked Data Working Group" ;
    schema:url "https://www.linked.data.gov.au"^^xsd:anyURI ;
.

:definition
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.04, 2.2.01 or 2.3.01 Each vocabulary, Collection or Concept MUST have exactly one title and at least one definition indicated using the skos:prefLabel and the skos:definition predicates respectively that must give textual literal values. Only one definition per language is allowed" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:string ;
        ]
        
        [
            sh:datatype rdf:langString ;
        ]
    ) ;
    sh:path skos:definition ;
    sh:uniqueLang true ;
    schema:name "definition" ;
.

:prefLabel
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.1.04, 2.2.1 or 2.3.1 Each vocabulary, Collection or Concept MUST have exactly one title and at least one definition indicated using the skos:prefLabel and the skos:definition predicates respectively that must give textual literal values. Only one definition per language is allowed" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:string ;
        ]
        
        [
            sh:datatype rdf:langString ;
        ]
    ) ;
    sh:path skos:prefLabel ;
    sh:uniqueLang true ;
    schema:name "prefLabel" ;
.

:status
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.1.10 The status of a vocabulary or a Concept SHOULD be given with the predicate schema:status and MAY be given with the predicate reg:status. Either, if used, MUST indicate a Concept from the Registry Statuses vocabulary (https://linked.data.gov.au/def/reg-statuses)" ;
    sh:nodeKind sh:IRI ;
    sh:path
        [
            sh:alternativePath (
                schema:status
                reg:status
            ) ;
        ] ;
    sh:severity sh:Warning ;
    schema:name "status" ;
.

<https://orcid.org/0000-0002-8742-7730>
    a schema:Person ;
    schema:email "nicholas.car@anu.edu.au"^^xsd:anyURI ;
    schema:identifier "https://orcid.org/0000-0002-8742-7730"^^xsd:anyURI ;
    schema:name "Nicholas J. Car" ;
.

:in-scheme
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.2.03 A Collections and Concepts MUST indicate any vocabulary they are used in with the skos:inScheme predicate" ;
    sh:minCount 1 ;
    sh:path skos:inScheme ;
    schema:name "in scheme" ;
.

:provenance-citation
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "schema:citation SHOULD be supplied and, if it is, MUST be a literal of type xsd:string or xsd:anyURI" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:anyURI ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path schema:citation ;
    sh:severity sh:Warning ;
    schema:name "provenance citation" ;
.

:provenance-dcterms-provenance
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "dcterms:provenance SHOULD be supplied and, if it is, MUST be a literal of type xsd:string or rdf:langString" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype rdf:langString ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path dcterms:provenance ;
    sh:severity sh:Warning ;
    schema:name "provenance dcterms:provenance" ;
.

:provenance-historyNote
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "skos:historyNote SHOULD be supplied and, if it is, MUST be a literal of type xsd:string or rdf:langString" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype rdf:langString ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path skos:historyNote ;
    sh:severity sh:Warning ;
    schema:name "provenance historyNote" ;
.

:provenance-source
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "dcterms:source SHOULD be supplied and, if it is, MUST be a literal of type xsd:string or xsd:anyURI" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:anyURI ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path dcterms:source ;
    sh:severity sh:Warning ;
    schema:name "provenance source" ;
.

:provenance-wasDerivedFrom
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "prov:wasDerivedFrom SHOULD be supplied and, if it is, MUST be an IRI" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path prov:wasDerivedFrom ;
    sh:severity sh:Warning ;
    schema:name "provenance wasDerivedFrom" ;
.

ont:
    a owl:Ontology ;
    owl:versionIRI :5.5 ;
    owl:versionInfo """5.5 2026-02: Added Shapes for Reqs 2.3.10 - 2.3.19

5.4 2026-02: Small fixes for a number of Issues raised in the Issue Tracker

5.3 ValPub valid. All propertyShape instances have IRIs, are not Blank Nodes. All Shapes have names & messages. SHACL-UI elements moved to shaclui.ttl

5.2 Implement Shape 2.1.2+3 using qualified shape pattern as this is supported by pySHACL

5.1 Remove targetNode -> ConceptScheme shape, use schema:, not schema:

5.0 Change IRI to linked.data.gov.au

4.11 Add VocEdit SHACL UI shapes and RDF statements

4.10 move all warning from PropertyShapes to NodeShapes

4.9 Fixed RDF syntax errors

4.8 Fixed Warning/Violation error for PropertyShapes

4.7 Fixed modified date alternate path listing bug

4.6 Fixed schema:historyNote->skos:historyNote bug

4.5 Added suggested predicates of license & copyrightHolder

4.4 Fixed versions across multiple Resources

4.3 Improved validator error messages by using more named Property Shapes

4.2: Included CONSTRUCT-based pre-validation inference in validator. First Git tagged version

4.1: Added Requirements 2.1.10, 2.1.11 & 2.1.12 and example RDF

4.0: Added a SPARQL function to allow for the inferencing of skos:inScheme predicates, skos:broader / skos:narrower and skos:topConceptOf/skos:hasTopConcept pairs of inverse predicates

3.3: Converted validator metadata to schema.org, enabled bibliographic references for Concepts, enabled DCTERMS or schema.org for many ConceptScheme predicates; simplified 2.1.6 from two Requirements to one; included skos:topConceptOf in 2.1.8 for Concepts at the top of the hierarchy; collapsed title & definition requirement pairs to single requirements

3.2: Allowed dcterms:provenance and skos:historyNote; removed max restriction on dcterms:source & prov:wasDerivedFrom

3.1: Changed dcterms:provenance to skos:historyNote

3.0: Removed Requirement-2.3.5 (identifiers) as these are auto-generated in systems like VocPrez; Added Requirement-2.1.10 & 2.1.11 and sub parts to test for qualifiedDerivation and status of a ConceptScheme""" ;
    skos:historyNote "Created to validate Australian government vocabularies in 2020. Now used widely." ;
    schema:codeRepository "https://github.com/AGLDWG/vocpub-profile/"^^xsd:anyURI ;
    schema:copyrightHolder <https://orcid.org/0000-0002-8742-7730> ;
    schema:creator <https://orcid.org/0000-0002-8742-7730> ;
    schema:dateCreated "2020-06-14"^^xsd:date ;
    schema:dateModified "2026-02-25"^^xsd:date ;
    schema:description "SHACL validator for the VocPub Profile" ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "VocPub Validator" ;
    schema:publisher <https://linked.data.gov.au/org/agldwg> ;
.
