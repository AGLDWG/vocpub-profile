PREFIX : <https://linked.data.gov.au/def/vocpub/validator-ga/>
PREFIX ont: <https://linked.data.gov.au/def/vocpub/validator-ga>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prof: <http://www.w3.org/ns/dx/prof/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<https://linked.data.gov.au/def/vocpub/validator/Requirement-GA.ECAT-ID>
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :conceptSchemeGaCatId ;
    sh:targetClass skos:ConceptScheme ;
    sh:message "GA.ECAT-ID Node Shape" ;
    schema:name "GA.ECAT-ID Node Shape" ;
.

:conceptSchemeGaCatId
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:anyURI ;
    sh:maxCount 1 ;
    sh:message "Requirement GA ECAT-ID: Each vocabulary MUST have exactly one identifier predicate indicating an eCatID, which means a schema:identifier predicate indicating a URL starting https://pid.geoscience.gov.au/dataset/ga/ and ending with a multi-digit number" ;
    sh:minCount 1 ;
    sh:path schema:identifier ;
    sh:pattern "^https://pid.geoscience.gov.au/dataset/ga/[0-9]+$" ;
    schema:name "GA.ECAT-ID Property Shape" ;
.

<https://linked.data.gov.au/org/ga>
    a schema:Organization ;
    schema:name "Geoscience Australia" ;
    schema:url "https://www.ga.gov.au"^^xsd:anyURI ;
.

<https://orcid.org/0000-0002-8742-7730>
    a schema:Person ;
    schema:email "nicholas.car@anu.edu.au"^^xsd:anyURI ;
    schema:identifier "https://orcid.org/0000-0002-8742-7730"^^xsd:anyURI ;
    schema:name "Nicholas J. Car" ;
.

ont:
    a owl:Ontology ;
    owl:versionIRI <https://linked.data.gov.au/def/vocpub/validator/5.5.GA> ;
    owl:versionInfo "5.5 2026-02: Aligns with use of VocPub 5.5. eCatID requirement for Concept Scheme only" ;
    prof:isProfileOf <https://linked.data.gov.au/def/vocpub/validator> ;
    schema:creator <https://orcid.org/0000-0002-8742-7730> ;
    schema:dateCreated "2020-06-14"^^xsd:date ;
    schema:dateModified "2026-02-25"^^xsd:date ;
    schema:dateIssued "2026-02-25"^^xsd:date ;
    schema:description "Geoscience Australia's additional vocabulary validation rules, to be added to VocPub" ;
    schema:name "VocPub Validator - GA"@en ;
    schema:publisher <https://linked.data.gov.au/org/ga> ;
    skos:historyNote "Previous to v5.5, this validator contained all of VocPub. Since 5.5 it contains only the GA-specific Shapes so must be used with VocPub (5.5+) to validate a vocabulary completely" ;
    schema:codeRepository "https://github.com/AGLDWG/vocpub-profile/"^^xsd:anyURI ;
    schema:copyrightHolder <https://linked.data.gov.au/org/ga> ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
.
